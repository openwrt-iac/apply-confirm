#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034
USE_PROCD=1
# shellcheck disable=SC2034
START=11
# shellcheck disable=SC2034
STOP=89

PROG=/usr/sbin/apply-confirm

boot() {
	# Recovery runs OFF the critical boot path. boot() executes synchronously in
	# the rc.d sequence, so a slow or stuck rollback here would wedge every later
	# service (dropbear, network) and lock the operator out: the exact outcome
	# this package exists to prevent. Detach it; the box finishes booting and the
	# rollback completes concurrently, ending in the restored config either way.
	( "$PROG" __recover boot >/dev/null 2>&1 & )
	start
}

start_service() {
	# Nothing to supervise unless an apply is armed.
	"$PROG" list 2>/dev/null | grep -q 'armed$' || return 0
	procd_open_instance apply-confirm
	procd_set_param command "$PROG" __supervise
	# Respawn for liveness: a killed supervisor comes back and re-reads its
	# durable deadline. It exits cleanly once the apply is no longer armed.
	procd_set_param respawn 0 2 0
	procd_close_instance
}
