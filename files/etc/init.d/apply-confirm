#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034
USE_PROCD=1
# shellcheck disable=SC2034
START=11
# shellcheck disable=SC2034
STOP=89

PROG=/usr/sbin/apply-confirm

boot() {
	# Just start the procd service. The supervisor daemon runs recovery as its
	# first action (see ac_supervise), so a single process owns both recovery and
	# supervision: no race between a separate boot-time recover pass and the
	# daemon, and recovery stays off the synchronous rc.d critical path (so a slow
	# rollback can never wedge later services).
	start
}

start_service() {
	# The supervisor is a persistent watcher, so it always runs. It idles cheaply
	# when nothing is armed and supervises an apply the moment one appears.
	# Default respawn restarts it only if it actually crashes (it never exits on
	# its own), so there is no respawn storm.
	procd_open_instance apply-confirm
	procd_set_param command "$PROG" __supervise
	procd_set_param respawn
	procd_close_instance
}
